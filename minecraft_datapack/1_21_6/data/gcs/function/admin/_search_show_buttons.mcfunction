# Open inline dialog for search result (no button row)
# Makro: hid, name, label, description, command, auth_level, category

$dialog show @s {type:"minecraft:multi_action",title:[{text:"🔍 ",color:"aqua"},{text:"$(label)",color:"white",bold:true}],body:{type:"minecraft:plain_message",contents:"§7$(description)\n§8ID: $(hid) | Category: $(category) | Auth Level: $(auth_level)"},can_close_with_escape:1b,pause:0b,columns:2,actions:[{label:"▶ Execute",action:{type:"minecraft:run_command",command:"/trigger gcs.exec set $(hid)"}},{label:"✏ Edit",action:{type:"minecraft:show_dialog",dialog:{type:"minecraft:multi_action",title:"✏ Handler Edit",inputs:[{type:"minecraft:text",key:"name",label:"Name",initial:"$(name)",max_length:32},{type:"minecraft:text",key:"label",label:"Label",initial:"$(label)",max_length:32},{type:"minecraft:text",key:"description",label:"Description",initial:"$(description)",max_length:64},{type:"minecraft:text",key:"command",label:"Command",initial:"$(command)",max_length:256},{type:"minecraft:single_option",key:"auth_level",label:"Auth Level",options:[{id:"1",display:"1 - User"},{id:"2",display:"2 - Moderator"},{id:"3",display:"3 - Admin"}],initial:"$(auth_level)"},{type:"minecraft:single_option",key:"category",label:"Category",options:[{id:"utility",display:"Utility"},{id:"teleport",display:"Teleport"},{id:"ability",display:"Ability"},{id:"world",display:"World"},{id:"admin",display:"Admin"}],initial:"$(category)"}],can_close_with_escape:1b,pause:0b,actions:[{label:"✔ Update",action:{type:"minecraft:dynamic/run_command",template:"/function gcs:admin/edit_handler {hid:$(hid),name:\"$(name)\",label:\"$(label)\",description:\"$(description)\",command:\"$(command)\",auth_level:$(auth_level),category:\"$(category)\"}"}}]}}},{label:"🔄 Toggle",action:{type:"minecraft:run_command",command:"/function gcs:admin/toggle_handler {hid:$(hid)}"}}]}
